# ─── Dependencies / build output ─────────────────────────────────────────
node_modules/
.next/
dist/
build/
out/
coverage/
.turbo/
.cache/

# ─── Secrets — NEVER commit ──────────────────────────────────────────────
# Catch every .env.* variant by default, then explicitly un-ignore the
# .env.example template files that DO belong in the repo.
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.pfx

# ─── Local databases (contain real user data) ────────────────────────────
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
data/
services/*/data/

# ─── Logs ────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
sentry-wizard-installation-error-*.log

# ─── Editor / OS ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# ─── Hardhat / Solidity ──────────────────────────────────────────────────
artifacts/
cache/
typechain-types/

# ─── Hosting / deploy ─────────────────────────────────────────────────────
.vercel/
.netlify/

# ─── Misc ────────────────────────────────────────────────────────────────
*.tsbuildinfo
.aider*
.claude/
.gemini/

# ─── Backups / scratch directories created during development ────────────
_landing.bak.*
*.bak

# Large static media served by the nginx media container (host-only, not in git)
media/

# Local-only Remotion video project (large, not part of the deploy)
/video/
