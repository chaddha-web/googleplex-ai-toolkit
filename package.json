{
  "name": "googolplex",
  "version": "0.0.0",
  "private": true,
  "description": "Googolplex Ecosystem — Web3 + Social + AI coding platform",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n web,admin,land,auth,gov,trsy,gas,ai,host,cid,id -c blue,magenta,white,green,cyan,green,yellow,red,white,gray,white 'npm:dev:web' 'npm:dev:admin' 'npm:dev:landing' 'npm:dev:auth' 'npm:dev:governance' 'npm:dev:handlers:treasury' 'npm:dev:handlers:gas' 'npm:dev:handlers:ai' 'npm:dev:handlers:hosting' 'npm:dev:handlers:cid' 'npm:dev:handlers:identity'",
    "dev:web": "npm run dev --workspace @googolplex/web",
    "dev:admin": "npm run dev --workspace @googolplex/admin",
    "dev:landing": "npm run dev --workspace @googolplex/landing",
    "build:landing": "npm run build --workspace @googolplex/landing",
    "dev:auth": "npm run dev --workspace @googolplex/auth",
    "dev:governance": "npm run dev --workspace @googolplex/governance-service",
    "build:web": "npm run build --workspace @googolplex/web",
    "compile:contracts": "npm run compile --workspace @googolplex/contracts",
    "test:contracts": "npm run test --workspace @googolplex/contracts",
    "dev:handlers:treasury": "npm run dev:treasury --workspace @googolplex/handlers",
    "dev:handlers:gas": "npm run dev:gas --workspace @googolplex/handlers",
    "dev:handlers:ai": "npm run dev:ai --workspace @googolplex/handlers",
    "dev:handlers:hosting": "npm run dev:hosting --workspace @googolplex/handlers",
    "dev:handlers:cid": "npm run dev:cid --workspace @googolplex/handlers",
    "dev:handlers:identity": "npm run dev:identity --workspace @googolplex/handlers"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "1.11.2",
    "@aws-sdk/client-ses": "3.1048.0",
    "@marsidev/react-turnstile": "1.5.2",
    "@next/bundle-analyzer": "16.2.6",
    "@react-email/components": "1.0.12",
    "@sentry/nextjs": "10.53.1",
    "@sentry/node": "10.53.1",
    "@simplewebauthn/browser": "^9.0.1",
    "@simplewebauthn/server": "^9.0.2",
    "better-sqlite3": "12.10.0",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.16.0",
    "next-auth": "5.0.0-beta.31",
    "pg": "8.20.0",
    "postgres": "3.4.9",
    "posthog-js": "1.373.5"
  }
}
