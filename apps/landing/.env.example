# ──────────────────────────────────────────────────────────────────────────
# Central auth backend (services/auth — Fastify) URL.
# This is what the signup/login forms and the /app dashboard call.
#
# Local dev:  http://localhost:4200   (default if unset)
# Production: https://api.ggakingclub.com
#
# Must be exposed to the browser, hence the NEXT_PUBLIC_ prefix.
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AUTH_BASE=http://localhost:4200

# ──────────────────────────────────────────────────────────────────────────
# LEGACY — the next routes at /api/otp/* are still present as a fallback
# but the live forms now call the central backend above. Leave these blank
# unless you specifically want to revive the in-Vercel OTP path.
# ──────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=GoogolPlex <start@ggakingclub.com>
OTP_SECRET=
