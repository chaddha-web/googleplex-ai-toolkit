# ──────────────────────────────────────────────────────────────────────────
# Chain RPCs
# ──────────────────────────────────────────────────────────────────────────
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org
TRON_API_URL=https://api.trongrid.io
TRON_API_KEY=
BTC_API_URL=https://mempool.space/api

# ──────────────────────────────────────────────────────────────────────────
# AWS KMS — for envelope-encrypting the master HD seeds.
# Use a Symmetric Encryption key (SYMMETRIC_DEFAULT). One key is enough.
# ──────────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
KMS_KEY_ID=arn:aws:kms:ap-south-1:000000000000:key/00000000-0000-0000-0000-000000000000

# ──────────────────────────────────────────────────────────────────────────
# Master xpubs — populated by `npm run init-seeds`.
# Leave blank initially; init-seeds prints the values for you to paste.
# These are PUBLIC keys (safe to commit-in-principle).
# ──────────────────────────────────────────────────────────────────────────
EVM_MASTER_XPUB=
BTC_MASTER_XPUB=
TRON_MASTER_XPUB=

# ──────────────────────────────────────────────────────────────────────────
# Balance refresh behaviour (JIT model)
# ──────────────────────────────────────────────────────────────────────────
# How long a per-user reconcile result is held in memory before another
# refresh actually hits the RPCs. Protects against spam-clicking the
# refresh button. 30s feels live without being wasteful.
REFRESH_CACHE_TTL_SECONDS=30
