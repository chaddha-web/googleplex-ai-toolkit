# Auth service env
# Drop into services/auth/.env (gitignored). Set the same vars in the
# deployment environment.

# Port the Fastify server listens on (default 4200).
PORT=4200

# Comma-separated list of allowed origins for CORS.
# Local dev defaults cover landing (3010), web (3000), admin (3001).
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3010

# Shared token for service-to-service communication
INTERNAL_SERVICE_TOKEN=

# SQLite file path. Created on first run.
AUTH_DB_PATH=./data/auth.db

# JWT signing secret. Min 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET=

# Access + refresh token TTLs (seconds). Defaults: 900 / 2592000.
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

# Resend — same as the standalone landing repo.
RESEND_API_KEY=
RESEND_FROM=GoogolPlex <start@ggakingclub.com>

# Comma-separated emails that get role='admin' on signup.
# Anyone NOT in this list signs up as role='user'. Existing user rows are
# not auto-upgraded — to promote an existing user, update the DB directly.
ADMIN_EMAILS=
# CORS — origins allowed to call this backend.
# In dev: landing on 3010, web on 3000, admin on 3001.
# In prod: lock to https://ggakingclub.com and subdomains via the regex
# pattern hardcoded in src/server.ts.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3010

# Shared token for service-to-service communication
INTERNAL_SERVICE_TOKEN=
