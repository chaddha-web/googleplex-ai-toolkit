# ─── Production env (DO NOT COMMIT — copy to .env.prod on the box) ───
# Generate fresh secrets with: openssl rand -hex 32

# Domain
DOMAIN=ggakingclub.com
LETSENCRYPT_EMAIL=start@ggakingclub.com

# Auth service
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
RESEND_API_KEY=REPLACE_WITH_real_resend_key
RESEND_FROM=GoogolPlex <start@ggakingclub.com>
ADMIN_EMAILS=Chaddhafateh0@gmail.com

# Cross-service (auth ↔ wallet)
INTERNAL_SERVICE_TOKEN=REPLACE_WITH_openssl_rand_hex_32

# Wallet — chain RPCs
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org
TRON_API_URL=https://api.trongrid.io
TRON_API_KEY=
BTC_API_URL=https://mempool.space/api

# Wallet — AWS KMS for master-seed envelope encryption
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
KMS_KEY_ID=

# Wallet — master xpubs (populate from `npm run init-seeds` output)
EVM_MASTER_XPUB=
BTC_MASTER_XPUB=
TRON_MASTER_XPUB=

# Wallet — JIT cache
REFRESH_CACHE_TTL_SECONDS=30

# Sentry (optional; leave blank to disable)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
